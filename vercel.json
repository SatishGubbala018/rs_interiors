{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },

    { "source": "/products(.*)", "destination": "/" },
    { "source": "/projects(.*)", "destination": "/" },
    { "source": "/contact(.*)", "destination": "/" },
    { "source": "/about(.*)", "destination": "/" },
    { "source": "/services(.*)", "destination": "/" },

    { "source": "/(.*)", "destination": "/" }
  ]
}


